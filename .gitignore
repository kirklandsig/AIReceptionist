__pycache__/
*.py[cod]
.env
.env.local
*.egg-info/
dist/
build/
.venv/
venv/
messages/
transcripts/
recordings/
.worktrees/
.pytest_cache/

# Private per-business configs — only the public `example-*.yaml` templates
# are tracked. Any other YAML in config/businesses/ is operator-local.
config/businesses/*.yaml
!config/businesses/example-*.yaml

# Per-business calendar credentials (service-account keys, OAuth tokens, OAuth client JSON)
secrets/*
!secrets/.gitkeep
